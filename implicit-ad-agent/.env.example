# ============================================================
# 隐式广告识别智能体 (Implicit Ad Agent) 环境配置
# 复制此文件为 .env 并填入你的真实值
# ============================================================

# ---------- LLM 配置（必填）----------
# 支持 OpenAI / DeepSeek / 通义千问 等兼容端点
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ---------- LangSmith 追踪（可选）----------
# 用于调试和可视化 LangGraph 执行轨迹
# LANGSMITH_API_KEY=your-langsmith-key
LANGSMITH_PROJECT=implicit-ad-agent

# ---------- 脱敏采集 ----------
# 用于生成稳定但不可逆的匿名 ID
ANONYMIZATION_SALT=114514
